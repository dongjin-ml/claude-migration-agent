# Vertex AI configuration for this sample customer project.
# Copy to .env and fill in real values before running.

ANTHROPIC_VERTEX_PROJECT_ID=my-fsi-project
CLOUD_ML_REGION=asia-southeast1

# Route all Vertex calls through an internal proxy/gateway instead of the
# default https://{region}-aiplatform.googleapis.com endpoint. The migration
# agent must NEVER remove or rewrite this — it is required for compliance.
ANTHROPIC_VERTEX_BASE_URL=https://internal-proxy.example.com/vertex

GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-service-account.json
