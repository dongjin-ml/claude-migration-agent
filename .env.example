# =============================================================
# Backend selection — set BACKEND to either "api" or "vertex"
# =============================================================
BACKEND=api

# -------------------------------------------------------------
# Used when BACKEND=api
# -------------------------------------------------------------
ANTHROPIC_API_KEY=your-api-key-here

# -------------------------------------------------------------
# Used when BACKEND=vertex
# (also run: gcloud auth application-default login)
# -------------------------------------------------------------
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=us-east5

# Optional: route Vertex calls through an internal proxy/gateway instead of
# the default https://{CLOUD_ML_REGION}-aiplatform.googleapis.com endpoint.
# Leave blank to use the default Google endpoint. The gateway must mirror the
# standard Vertex path: /v1/projects/{project_id}/locations/{region}/...
# Both the eval client (anthropic SDK) and the scan/fix client (Claude Code
# CLI) read this variable.
# Example: ANTHROPIC_VERTEX_BASE_URL=https://your-internal-gateway/v1
ANTHROPIC_VERTEX_BASE_URL=

# =============================================================
# Models
# -------------------------------------------------------------
# Model ID format depends on BACKEND:
#
#   BACKEND=api      Alias OR dated form both work:
#                      claude-sonnet-4-6
#                      claude-sonnet-4-6-20251015
#
#   BACKEND=vertex   Dated form is always safe:
#                      claude-sonnet-4-6@20251015
#                    Alias form may also work only if your GCP
#                    project publishes alias routing. If unsure,
#                    check which model IDs your Vertex project
#                    has enabled and use that exact string.
#
# Official model list (dates & aliases):
#   https://platform.claude.com/docs/en/about-claude/models
# =============================================================

# Model used by the migration agent itself (scan, fix, autopilot)
AGENT_MODEL=claude-sonnet-4-6

# Model used for evaluation (LLM-as-Judge) in eval mode
EVAL_MODEL=claude-sonnet-4-6

# Max scan → fix → eval iterations in autopilot mode
MAX_EVAL_ITERATIONS=3
